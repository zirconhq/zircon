{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "service": "devcontainer",
  "dockerComposeFile": "compose.yaml",
  "workspaceFolder": "/workspaces/james",
  "containerEnv": {
    "CONTAINER_WORKSPACE_VOLUME": "${containerWorkspaceFolder}",
    "LOCAL_WORKSPACE_VOLUME": "${localWorkspaceFolder}"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "chat.tools.terminal.autoApprove": {
          "/.*/": true
        }
      },
      "extensions": [
        "redhat.vscode-yaml",
        "Vue.volar",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}