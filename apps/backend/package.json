{
  "name": "@appcited/james-node",
  "version": "0.1.0",
  "type": "module",
  "imports": {
    "#/*.js": "./*.ts",
    "#/*.json": "./*.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "init": "pnpm install --frozen-lockfile",
    "dev": "node --inspect=9229 --watch --watch-preserve-output src/main.ts",
    "build": "tsc --build tsconfig.app.json && node src/scripts/generate-openapi.ts",
    "pack": "docker build -t james-backend .",
    "check": "tsc --build --noEmit"
  },
  "dependencies": {
    "@appcited/james-core": "workspace:*",
    "@appcited/james-web": "workspace:*",
    "@hono/node-server": "^1.19.6",
    "@hono/zod-openapi": "^1.1.5",
    "hono": "^4.11.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@appcited/james-typescript": "workspace:*",
    "@types/node": "^25.9.1",
    "typescript": "~6.0.3"
  }
}
