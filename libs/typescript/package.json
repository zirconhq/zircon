{
  "name": "@appcited/james-typescript",
  "type": "module",
  "imports": {
    "#/*.json": "./*.json"
  },
  "scripts": {
    "init": "pnpm install --frozen-lockfile",
    "build": "mkdir -p dist && cp -r src/* dist/"
