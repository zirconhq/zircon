{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "composite": true,
    "outDir": "${configDir}/dist",
    "lib": ["ESNext"],
    "declaration": true,
    "declarationMap": true,
    "resolveJsonModule": true,
    "checkJs": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "tsBuildInfoFile": "${configDir}/node_modules/.tmp/tsconfig.tsbuildinfo"
  }
}
